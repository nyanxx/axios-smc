{
  "name": "ud-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm exec tsc",
    "start": "pnpm exec tsc && node dist/index.js",
    "dev:norm": "nodemon src/index.ts",
    "dev:1": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/server.ts",
    "dev:2": "nodemon --exec ts-node src/index.ts",
    "dev:3": "tsx watch src/index.ts",
    "dev:dotenvx": "pnpm dotenvx run -- nodemon src/index.ts",
    "dev": "pnpm run dev:2",
    "pretty": "pnpm exec prettier . --check",
    "pretty:write": "pnpm exec prettier . --write",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.59.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "prettier": "3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
